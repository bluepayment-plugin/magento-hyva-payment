                        return false;
                    }

                    if (this.isSavedCardsVisible && (this.selectedCardIndex === null || this.selectedCardIndex === '')) {
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('You have to select card.')) ?>');
                        return false;
                    }

                    if (this.isOneClickAgreementVisible && !this.acceptedOneClickAgreement) {
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('You have to agree with terms.')) ?>');
                        return false;
                    }

                    return true;
                },

                async placeOrderOnWire() {
                    const state = getBluepaymentRetryState();
                    const placement = waitForOrderPlacement();

                    state.paymentInProgress = true;
                    state.suppressEmptyCartDialog = true;
                    syncBluepaymentInteractionState();
                    this.logDebug('order.placeOnWire.start');

                    try {
                        await hyvaCheckout.main.getWireComponent().placeOrder(hyvaCheckout.storage.data);
                        const placed = await placement;

                        if (!placed) {
                            state.paymentInProgress = false;
                            state.suppressEmptyCartDialog = false;
                            syncBluepaymentInteractionState();
                        }

                        this.logDebug('order.placeOnWire.result', {
                            placed
                        });
                        return placed;
                    } catch (error) {
                        state.paymentInProgress = false;
                        state.suppressEmptyCartDialog = false;
                        syncBluepaymentInteractionState();
                        this.logDebug('order.placeOnWire.error', {
                            message: error?.message || null
                        });
                        throw error;
                    }
                },

                async handoffPlaceOrderToActiveMethod() {
                    const activeMethodCode = getActiveBluepaymentMethodCode();

                    if (!activeMethodCode || activeMethodCode === this.methodCode) {
                        return null;
                    }

                    const activeComponent = window.bluepaymentHyva?.[activeMethodCode] || null;

                    if (!activeComponent
                        || activeComponent === this
                        || typeof activeComponent.placeOrder !== 'function'
                    ) {
                        return null;
                    }

                    this.logDebug('placeOrder.delegateToActiveMethod', {
                        activeMethodCode
                    });

                    return activeComponent.placeOrder();
                },

                async placeOrder() {
                    const delegatedResult = await this.handoffPlaceOrderToActiveMethod();

                    if (delegatedResult !== null) {
                        return delegatedResult;
                    }

                    clearBluepaymentAlerts();
                    this.logDebug('placeOrder.start', {
                        orderAlreadyPlaced: getBluepaymentRetryState().orderPlaced
                    });

                    if (!this.validate()) {
                        return false;
                    }

                    if (this.isGooglePaySelected()) {
                        const token = await this.requestGooglePayToken();
                        if (!token) {
                            return false;
                        }

                        if (getBluepaymentRetryState().orderPlaced) {
                            return this.continuePlacedOrderPayment({ googlePayToken: token });
                        }

                        const placed = await this.placeOrderOnWire();
                        if (!placed) {
                            return false;
                        }

                        this.markOrderPlaced();
                        await this.continuePlacedOrderPayment({ googlePayToken: token });
                        return true;
                    }

                    if (getBluepaymentRetryState().orderPlaced) {
                        this.logDebug('placeOrder.continueExistingOrder');
                        return this.continuePlacedOrderPayment();
                    }

                    const placed = await this.placeOrderOnWire();
                    if (!placed) {
                        return false;
                    }

                    this.markOrderPlaced();
                    return this.continuePlacedOrderPayment();
                },

                async ensureGooglePayReady() {
                    try {
                        await loadScript('https://pay.google.com/gp/p/js/pay.js');

                        const response = await fetchJson(this.config.google_pay_url);
                        if (response.error) {
                            this.googlePayAvailable = false;
                            return false;
                        }

                        this.googlePayMerchantInfo = response.merchantInfo;
                        this.googlePayAcceptorId = String(response.acceptorId);
                        this.googlePayClient = new google.payments.api.PaymentsClient({
                            environment: this.config.test_mode ? 'TEST' : 'PRODUCTION'
                        });
                        this.googlePayAvailable = true;

                        return true;
                    } catch (error) {
                        this.googlePayAvailable = false;
                        return false;
                    }
                },

                getGooglePayTransactionData() {
                    return {
                        apiVersion: 2,
                        apiVersionMinor: 0,
                        merchantInfo: this.googlePayMerchantInfo,
                        allowedPaymentMethods: [{
                            type: 'CARD',
                            parameters: {
                                allowedAuthMethods: ['PAN_ONLY', 'CRYPTOGRAM_3DS'],
                                allowedCardNetworks: ['MASTERCARD', 'VISA']
                            },
                            tokenizationSpecification: {
                                type: 'PAYMENT_GATEWAY',
                                parameters: {
                                    gateway: 'bluemedia',
                                    gatewayMerchantId: this.googlePayAcceptorId
                                }
                            }
                        }],
                        shippingAddressRequired: false,
                        transactionInfo: {
                            totalPriceStatus: 'FINAL',
                            totalPrice: String(this.config.grand_total || '0.00'),
                            currencyCode: this.config.currency_code || 'PLN'
                        }
                    };
                },

                async requestGooglePayToken() {
                    const ready = this.googlePayClient || await this.ensureGooglePayReady();
                    if (!ready || !this.googlePayClient) {
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('Google Pay is not available right now.')) ?>');
                        return null;
                    }

                    try {
                        const data = await this.googlePayClient.loadPaymentData(this.getGooglePayTransactionData());
                        return data?.paymentMethodData?.tokenizationData?.token || null;
                    } catch (error) {
                        return null;
                    }
                },

                async startGooglePayPayment(token) {
                    try {
                        const response = await postJson(this.config.create_url, this.getCreateRequestPayload({ token }));

                        if (response?.params?.redirectUrl) {
                            window.location.assign(response.params.redirectUrl);
                            return;
                        }

                        if (response?.params?.paymentStatus) {
                            this.pollPaymentStatus(response.params, {
                                attemptId: getBluepaymentRetryState().paymentAttemptId
                            });
                            return;
                        }
                    } catch (error) {
                    }

                    this.enterRetryMode();
                    showBluepaymentAlert('<?= $escaper->escapeJs(__('Payment could not be started. Please try again.')) ?>');
                },

                async startBlikPayment() {
                    this.logDebug('blik.start.request');

                    try {
                        const response = await postJson(this.config.create_url, this.getCreateRequestPayload({
                            code: this.blikCode
                        }));
                        const responseParams = response?.params || {};

                        this.logDebug('blik.start.response', {
                            confirmation: responseParams.confirmation || null,
                            hasPaymentStatus: hasOwn(responseParams, 'paymentStatus'),
                            paymentStatus: responseParams.paymentStatus ?? null,
                            gatewayId: responseParams.GatewayID ?? null
                        });

                        if (responseParams.confirmation === 'NOTCONFIRMED') {
                            this.enterRetryMode();
                            showBluepaymentAlert('<?= $escaper->escapeJs(__('Invalid BLIK code.')) ?>');
                            return;
                        }

                        if (responseParams.confirmation === 'CONFIRMED' || hasOwn(responseParams, 'paymentStatus')) {
                            this.startBlikRetryTimeout();
                            this.pollPaymentStatus(responseParams, {
                                attemptId: getBluepaymentRetryState().paymentAttemptId
                            });
                            return;
                        }
                    } catch (error) {
                        this.logDebug('blik.start.error', {
                            message: error?.message || null
                        });
                    }

                    this.enterRetryMode();
                    showBluepaymentAlert('<?= $escaper->escapeJs(__('Payment could not be started. Please try again.')) ?>');
                },

                pollPaymentStatus(params, { attemptId = null } = {}) {
                    const activeAttemptId = attemptId ?? getBluepaymentRetryState().paymentAttemptId;
                    const isBlikFlow = Number(params?.GatewayID) === Number(this.config.gateways_ids?.blik)
                        || this.isBlikCodeVisible;

                    this.logDebug('paymentStatus.poll.enter', {
                        activeAttemptId,
                        paramsGatewayId: params?.GatewayID ?? null,
                        paymentStatus: params?.paymentStatus ?? null,
                        isBlikFlow
                    });

                    if (activeAttemptId === null || getBluepaymentRetryState().paymentAttemptId !== activeAttemptId) {
                        this.logDebug('paymentStatus.poll.skip.staleAttempt', {
                            activeAttemptId
                        });
                        return;
                    }

                    if (params.paymentStatus === 'SUCCESS') {
                        this.logDebug('paymentStatus.poll.success', {
                            activeAttemptId
                        });
                        this.clearPaymentStatusPolling();
                        this.clearBlikTimeout();
                        window.location.assign(buildUrl(this.config.back_url, {
                            ServiceID: params.ServiceID,
                            OrderID: params.OrderID,
                            Hash: params.hash,
                            Status: 'SUCCESS'
                        }));
                        return;
                    }

                    if (params.paymentStatus === 'FAILURE') {
                        this.logDebug('paymentStatus.poll.failure', {
                            activeAttemptId
                        });
                        this.clearPaymentStatusPolling();
                        this.clearBlikTimeout();
                        this.enterRetryMode();
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('Payment failed. Please try again or use a different payment method.')) ?>');
                        return;
                    }

                    this.clearPaymentStatusPolling({
                        preserveBlikConfirmation: isBlikFlow
                    });

                    if (isBlikFlow) {
                        this.showBlikConfirmationModal();
                    }

                    getBluepaymentRetryState().paymentInProgress = true;
                    syncBluepaymentInteractionState();
                    getBluepaymentRetryState().pollTimerId = window.setTimeout(async () => {
                        try {
                            if (getBluepaymentRetryState().paymentAttemptId !== activeAttemptId) {
                                this.logDebug('paymentStatus.poll.timer.skip.staleAttempt', {
                                    activeAttemptId
                                });
                                return;
                            }

                            const response = await fetchJson(this.config.payment_status_url);

                            if (getBluepaymentRetryState().paymentAttemptId !== activeAttemptId) {
                                this.logDebug('paymentStatus.poll.response.skip.staleAttempt', {
                                    activeAttemptId
                                });
                                return;
                            }

                            this.logDebug('paymentStatus.poll.response', {
                                activeAttemptId,
                                responseStatus: response?.Status ?? null,
                                responseGatewayId: response?.GatewayID ?? null
                            });

                            if (hasOwn(response, 'Status')) {
                                this.pollPaymentStatus({
                                    ServiceID: response.ServiceID,
                                    OrderID: response.OrderID,
                                    hash: response.hash,
                                    paymentStatus: response.Status
                                }, {
                                    attemptId: activeAttemptId
                                });
                            }
                        } catch (error) {
                            if (getBluepaymentRetryState().paymentAttemptId !== activeAttemptId) {
                                this.logDebug('paymentStatus.poll.error.skip.staleAttempt', {
                                    activeAttemptId
                                });
                                return;
                            }

                            this.logDebug('paymentStatus.poll.error', {
                                activeAttemptId,
                                message: error?.message || null
                            });
                            this.enterRetryMode();
                            showBluepaymentAlert('<?= $escaper->escapeJs(__('Unable to verify payment status.')) ?>');
                        }
                    }, 2000);
                },

                getWidgetHost() {
                    return this.config.test_mode ? 'https://testcards.autopay.eu' : 'https://cards.autopay.eu';
                },

                getWidgetFrame() {
                    return document.getElementById(this.widgetFrameId);
                },

                getWidgetConfig() {
                    const widgetConfig = {
                        language: document.documentElement.lang?.toLowerCase().split('-')[0] || 'pl',
                        amount: Number(this.config.grand_total || 0),
                        currency: this.config.currency_code || 'PLN',
                        serviceId: Number(this.config.service_id || 0)
                    };

                    if (Number(this.selectedGatewayId) === Number(this.config.gateways_ids?.one_click)
                        && Number(this.selectedCardIndex) === -1
                    ) {
                        widgetConfig.recurringAction = 'INIT_WITH_PAYMENT';
                    }

                    return widgetConfig;
                },

                async ensureWidgetInitialized() {
                    if (!this.isWidgetFrameVisible) {
                        return;
                    }

                    try {
                        await loadScript(`${this.getWidgetHost()}/widget-new/widget-communication.min.js`);
                    } catch (error) {
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('Card form is unavailable right now.')) ?>');
                        return;
                    }

                    const frame = this.getWidgetFrame();
                    if (!frame || typeof WidgetConnection === 'undefined' || typeof widgetEvents === 'undefined') {
                        return;
                    }

                    if (this.widget) {
                        return;
                    }

                    frame.src = `${this.getWidgetHost()}/widget-new/partner`;
                    this.widget = new WidgetConnection(this.getWidgetConfig());

                    this.widget.startConnection(frame).then(() => {
                        this.widgetReady = true;
                        this.widget.on(widgetEvents.formSuccess, this.onWidgetSuccess.bind(this));
                        this.widget.on(widgetEvents.formError, this.onWidgetError.bind(this));
                        this.widget.on(widgetEvents.validityStatus, this.onWidgetValidity.bind(this));
                        this.widget.on(widgetEvents.validationResult, this.onWidgetValidity.bind(this));
                    }).catch(() => {
                        this.resetWidget();
                    });
                },

                callWidgetPayment() {
                    if (!this.widget || !this.widgetReady) {
                        this.enterRetryMode();
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('Card form is not ready yet. Please wait a moment and try again.')) ?>');
                        return;
                    }

                    if (this.widget.invalid === true || this.widgetValid === false) {
                        this.widget.validateForm();
                        this.enterRetryMode();
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('Please complete card data correctly.')) ?>');
                        return;
                    }

                    this.markPaymentAttemptStarted();
                    this.widget.sendForm();
                },

                onWidgetValidity(message, eventData) {
                    this.widgetValid = Boolean(eventData && eventData.valid);
                },

                async onWidgetSuccess(message, eventData) {
                    const token = typeof message === 'string'
                        ? message
                        : eventData?.message || message?.message || '';

                    if (!token) {
                        this.enterRetryMode();
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('Card token is missing. Please try again.')) ?>');
                        return;
                    }

                    try {
                        const response = await postJson(this.config.create_url, {
                            gateway_id: this.selectedGatewayId,
                            automatic: true,
                            token,
                            card_index: this.selectedCardIndex
                        });

                        if (response?.redirect_url) {
                            window.location.assign(response.redirect_url);
                            return;
                        }
                    } catch (error) {
                    }

                    this.enterRetryMode();
                    showBluepaymentAlert('<?= $escaper->escapeJs(__('Payment request failed. Please try again.')) ?>');
                },

                onWidgetError() {
                    this.enterRetryMode();
                    showBluepaymentAlert('<?= $escaper->escapeJs(__('Check card form fields and try again.')) ?>');
                },

                resetWidget() {
                    if (this.widget && typeof this.widget.stopConnection === 'function') {
                        this.widget.stopConnection();
                    }

                    const frame = this.getWidgetFrame();
                    if (frame) {
                        frame.removeAttribute('src');
                    }

                    this.widget = null;
                    this.widgetReady = false;
                    this.widgetValid = false;
                }
            }));

            hyvaCheckout.api.priority(() => {
                registerAvailableBluepaymentMethods();
                overrideBluepaymentEmptyCartDialog();
                registerBluepaymentStorageListener();
            });

            syncBluepaymentRetryStateFromCheckout();

            const activeMethodCode = getActiveBluepaymentMethodCode();

            if (activeMethodCode) {
                const methodRoot = getBluepaymentRootByMethodCode(activeMethodCode);

                if (methodRoot) {
                    initBluepaymentTree(methodRoot);
                }
            }

            syncExistingBluepaymentGatewayStates();
            syncExistingBluepaymentCardStates();
            syncBluepaymentInteractionState();
            registerBluepaymentMethodSelectionHandler();
            registerBluepaymentGatewayClickHandler();
            registerBluepaymentSavedCardClickHandler();
            registerBluepaymentMagewireHook();
        };

        if (window.Alpine && typeof window.Alpine.data === 'function') {
            registerBluepaymentMethodComponent();
        } else {
            document.addEventListener('alpine:init', registerBluepaymentMethodComponent, { once: true });
        }

        window.addEventListener('checkout:init:evaluation', () => {
            hyvaCheckout.api.priority(() => {
                registerAvailableBluepaymentMethods();
                overrideBluepaymentEmptyCartDialog();
                registerBluepaymentStorageListener();
            });

            syncBluepaymentRetryStateFromCheckout();

            const activeMethodCode = getActiveBluepaymentMethodCode();

            if (activeMethodCode) {
                const methodRoot = getBluepaymentRootByMethodCode(activeMethodCode);

                if (methodRoot) {
                    initBluepaymentTree(methodRoot);
                }
            }

            syncExistingBluepaymentGatewayStates();
            syncExistingBluepaymentCardStates();
            syncBluepaymentInteractionState();
            registerBluepaymentMethodSelectionHandler();
            registerBluepaymentGatewayClickHandler();
            registerBluepaymentSavedCardClickHandler();
            registerBluepaymentMagewireHook();
        });
    })();
</script>
