<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

$hyvaCsp = $viewModels->require(HyvaCsp::class);
?>
<script>
    (() => {
        const isBluepaymentMethodCode = (code) => code === 'bluepayment' || String(code || '').startsWith('bluepayment_');

        const loadScript = (src) => {
            const existing = document.querySelector(`script[src="${src}"]`);

            if (existing) {
                if (existing.dataset.loaded === 'true') {
                    return Promise.resolve();
                }

                return new Promise((resolve, reject) => {
                    existing.addEventListener('load', () => resolve(), { once: true });
                    existing.addEventListener('error', () => reject(new Error(`Unable to load ${src}`)), { once: true });
                });
            }

            return new Promise((resolve, reject) => {
                const script = document.createElement('script');
                script.src = src;
                script.async = true;
                script.addEventListener('load', () => {
                    script.dataset.loaded = 'true';
                    resolve();
                }, { once: true });
                script.addEventListener('error', () => reject(new Error(`Unable to load ${src}`)), { once: true });
                document.head.appendChild(script);
            });
        };

        const buildUrl = (baseUrl, params = {}) => {
            const url = new URL(baseUrl, window.location.origin);

            Object.entries(params).forEach(([key, value]) => {
                if (value !== null && value !== undefined && value !== '') {
                    url.searchParams.set(key, String(value));
                }
            });

            return url.toString();
        };

        const hasOwn = (value, key) => Object.prototype.hasOwnProperty.call(value || {}, key);

        const fetchJson = async (url, options = {}) => {
            const response = await fetch(url, Object.assign({
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'same-origin'
            }, options));

            if (!response.ok) {
                throw new Error(`Request failed with status ${response.status}`);
            }

            return response.json();
        };

        const postJson = async (url, payload = {}) => {
            const formData = new URLSearchParams();
            Object.entries(payload).forEach(([key, value]) => {
                if (value !== null && value !== undefined) {
                    formData.append(key, String(value));
                }
            });

            formData.append('form_key', window.FORM_KEY || '');

            return fetchJson(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: formData.toString()
            });
        };

        const waitForOrderPlacement = () => new Promise((resolve) => {
            let resolved = false;

            const finalize = (result) => {
                if (resolved) {
                    return;
                }

                resolved = true;
                clearTimeout(timeoutId);
                window.removeEventListener('order:place:success', successHandler);
                window.removeEventListener('order:place:error', errorHandler);
                resolve(result);
            };

            const successHandler = () => finalize(true);
            const errorHandler = () => finalize(false);
            const timeoutId = window.setTimeout(() => finalize(false), 30000);

            window.addEventListener('order:place:success', successHandler, { once: true });
            window.addEventListener('order:place:error', errorHandler, { once: true });
        });

        const createBluepaymentRetryState = () => ({
            orderPlaced: false,
            retryMode: false,
            paymentInProgress: false,
            activeMethodCode: null,
            pollTimerId: null,
            blikTimeoutId: null,
            blikConfirmationVisible: false,
            paymentAttemptId: null,
            suppressEmptyCartDialog: false
        });

        const getBluepaymentRetryState = () => {
            window.bluepaymentHyvaRetryState = window.bluepaymentHyvaRetryState || createBluepaymentRetryState();

            return window.bluepaymentHyvaRetryState;
        };

        const getBluepaymentUiStateStore = () => {
            window.bluepaymentHyvaUiState = window.bluepaymentHyvaUiState || {};

            return window.bluepaymentHyvaUiState;
        };

        const getBluepaymentUiState = (methodCode) => {
            if (!isBluepaymentMethodCode(methodCode)) {
                return {};
            }

            const store = getBluepaymentUiStateStore();
            store[methodCode] = store[methodCode] || {};

            return store[methodCode];
        };

        const setBluepaymentUiState = (methodCode, values = {}) => {
            if (!isBluepaymentMethodCode(methodCode) || typeof values !== 'object' || values === null) {
                return {};
            }

            const store = getBluepaymentUiStateStore();
            store[methodCode] = Object.assign({}, store[methodCode] || {}, values);

            return store[methodCode];
        };

        const getBluepaymentRetryStateSnapshot = () => {
            const state = getBluepaymentRetryState();

            return {
                orderPlaced: state.orderPlaced,
                retryMode: state.retryMode,
                paymentInProgress: state.paymentInProgress,
                activeMethodCode: state.activeMethodCode,
                pollTimerActive: state.pollTimerId !== null,
                blikTimeoutActive: state.blikTimeoutId !== null,
                blikConfirmationVisible: state.blikConfirmationVisible,
                paymentAttemptId: state.paymentAttemptId,
                suppressEmptyCartDialog: state.suppressEmptyCartDialog
            };
        };

        const getBluepaymentUiStateSnapshot = (methodCode) => {
            const uiState = getBluepaymentUiState(methodCode);

            return {
                selectedGatewayId: uiState.selectedGatewayId ?? null,
                selectedCardIndex: uiState.selectedCardIndex ?? null,
                blikCodeLength: String(uiState.blikCode || '').length,
                acceptedOneClickAgreement: Boolean(uiState.acceptedOneClickAgreement)
            };
        };

        const bluepaymentDebugLog = (event, context = {}) => {
            if (window.BLUEPAYMENT_HYVA_DEBUG === false
                || !window.console
                || typeof window.console.info !== 'function'
            ) {
                return;
            }

            window.console.info('[Bluepayment Hyva]', event, context);
        };

        const getPaymentMethodListElement = () => document.getElementById('payment-method-list');
        const getBluepaymentProcessingOverlayElement = () => document.getElementById('bluepayment-processing-overlay');

        const normalizeAlertText = (text) => String(text || '').trim();
        const bluepaymentAlertCleanupScope = Object.freeze({
            ALL: 'all',
            BLIK: 'blik'
        });

        const bluepaymentAlertMessages = new Set();
        const bluepaymentKnownBlikAlertMessages = new Set([
            normalizeAlertText('<?= $escaper->escapeJs(__('Choose the way you want to pay.')) ?>'),
            normalizeAlertText('<?= $escaper->escapeJs(__('Invalid BLIK code.')) ?>'),
            normalizeAlertText('<?= $escaper->escapeJs(__('The BLIK code has expired. Try again.')) ?>'),
            normalizeAlertText('<?= $escaper->escapeJs(__('Payment could not be started. Please try again.')) ?>')
        ]);
        const bluepaymentKnownAlertMessages = new Set([
            ...bluepaymentKnownBlikAlertMessages,
            normalizeAlertText('<?= $escaper->escapeJs(__('You have to select card.')) ?>'),
            normalizeAlertText('<?= $escaper->escapeJs(__('You have to agree with terms.')) ?>'),
            normalizeAlertText('<?= $escaper->escapeJs(__('The selected payment channel is no longer available.')) ?>'),
            normalizeAlertText('<?= $escaper->escapeJs(__('This order can only be completed using Autopay methods.')) ?>')
        ]);

        const isBluepaymentAlertMessage = (text, scope = bluepaymentAlertCleanupScope.ALL) => {
            const normalizedText = normalizeAlertText(text);
            const scopedMessages = scope === bluepaymentAlertCleanupScope.BLIK
                ? bluepaymentKnownBlikAlertMessages
                : bluepaymentKnownAlertMessages;

            return bluepaymentAlertMessages.has(normalizedText)
                || scopedMessages.has(normalizedText);
        };

        const filterBluepaymentAlerts = (messages, scope = bluepaymentAlertCleanupScope.ALL) => {
            if (!Array.isArray(messages)) {
                return [];
            }

            return messages.filter((message) => {
                if (!message || typeof message.text !== 'string') {
                    return message !== undefined && message !== null;
                }

                return !isBluepaymentAlertMessage(message.text, scope);
            });
        };

        const dedupeMessages = (messages) => {
            const seen = new Set();

            return (Array.isArray(messages) ? messages : []).reduce((result, message) => {
                if (!message || typeof message.text !== 'string') {
                    return result;
                }

                const key = `${ message.type || 'notice' }::${ normalizeAlertText(message.text) }`;

                if (seen.has(key)) {
                    return result;
                }

                seen.add(key);
                result.push(message);
                return result;
            }, []);
        };

        const clearBluepaymentAlerts = (scope = bluepaymentAlertCleanupScope.ALL) => {
            const messagesRoot = document.getElementById('messages');
            const messagesComponent = messagesRoot?._x_dataStack?.[0] || null;
            const componentMessages = filterBluepaymentAlerts(messagesComponent?.messages, scope);
            const mageMessages = filterBluepaymentAlerts(window.mageMessages, scope);
            const dispatchedMessages = filterBluepaymentAlerts(window.dispatchedMessages, scope);
            const preservedMessages = dedupeMessages([
                ...componentMessages,
                ...mageMessages,
                ...dispatchedMessages
            ]);

            if (Array.isArray(window.mageMessages)) {
                window.mageMessages = mageMessages;
            }

            if (Array.isArray(window.dispatchedMessages)) {
                window.dispatchedMessages = dispatchedMessages;
            }

            window.dispatchEvent(new Event('clear-messages'));

            if (messagesComponent && Array.isArray(messagesComponent.messages)) {
                messagesComponent.messages = preservedMessages;
            } else if (preservedMessages.length > 0) {
                window.dispatchEvent(new CustomEvent('messages-loaded', {
                    detail: {
                        messages: preservedMessages
                    }
                }));
            }

            document.querySelectorAll('#messages .message').forEach((messageElement) => {
                if (isBluepaymentAlertMessage(messageElement.textContent || '', scope)) {
                    messageElement.remove();
                }
            });
        };

        const scheduleBluepaymentAlertCleanup = (scope = bluepaymentAlertCleanupScope.ALL) => {
            clearBluepaymentAlerts(scope);

            window.requestAnimationFrame(() => {
                clearBluepaymentAlerts(scope);
            });

            window.setTimeout(() => {
                clearBluepaymentAlerts(scope);
            }, 150);
        };

        const showBluepaymentAlert = (text, duration) => {
            const normalizedText = normalizeAlertText(text);

            if (normalizedText === '') {
                return;
            }

            bluepaymentAlertMessages.add(normalizedText);
            clearBluepaymentAlerts();
            hyvaCheckout.message.alert(normalizedText, duration);
        };

        const getCheckoutPaymentMethodCode = () => {
            const configuredMethod = window.hyvaCheckout?.config?.getValue?.('payment.method');

            if (typeof configuredMethod === 'string' && configuredMethod !== '') {
                return configuredMethod;
            }

            return getPaymentMethodListElement()?.dataset.method || null;
        };

        const setCheckoutPaymentMethodCode = (code) => {
            if (typeof code !== 'string' || code === '') {
                return;
            }

            const list = getPaymentMethodListElement();

            if (list) {
                list.dataset.method = code;
            }

            if (!window.hyvaCheckout?.config?.config) {
                return;
            }

            window.hyvaCheckout.config.config.payment = window.hyvaCheckout.config.config.payment || {};
            window.hyvaCheckout.config.config.payment.method = code;
        };

        const getActiveBluepaymentMethodCode = () => {
            const state = getBluepaymentRetryState();
            const checkoutMethodCode = getCheckoutPaymentMethodCode();

            if (isBluepaymentMethodCode(state.activeMethodCode)) {
                return state.activeMethodCode;
            }

            if (isBluepaymentMethodCode(checkoutMethodCode)) {
                return checkoutMethodCode;
            }

            return null;
        };

        const syncBluepaymentBlikConfirmationVisibility = () => {
            const state = getBluepaymentRetryState();
            const activeMethodCode = getActiveBluepaymentMethodCode();
            const components = Object.values(window.bluepaymentHyva || {});

            components.forEach((component) => {
                if (!component || !Object.prototype.hasOwnProperty.call(component, 'blikConfirmationVisible')) {
                    return;
                }

                const isActiveComponent = component.methodCode === activeMethodCode;
                const canShowBlikConfirmation = typeof component.isBlikCodeVisible === 'boolean'
                    ? component.isBlikCodeVisible
                    : false;

                component.blikConfirmationVisible = Boolean(state.blikConfirmationVisible)
                    && isActiveComponent
                    && canShowBlikConfirmation;
            });
        };

        const shouldSuppressBluepaymentEmptyCartDialog = () => {
            const state = getBluepaymentRetryState();

            return state.suppressEmptyCartDialog === true;
        };

        const syncBluepaymentMethodViewState = (activeMethodCode = null) => {
            document.querySelectorAll('[data-autopay-method-option]').forEach((option) => {
                const optionCode = option.dataset.autopayMethodOption || '';
                const isActive = activeMethodCode !== null && optionCode === activeMethodCode;
                const input = option.querySelector('input[name="payment-method-option"]');

                option.classList.toggle('active', isActive);
                option.classList.toggle('bg-primary', isActive);
                option.classList.toggle('bg-opacity-10', isActive);
                option.classList.toggle('border-primary', isActive);
                option.classList.toggle('inactive', !isActive);
                option.classList.toggle('bg-white', !isActive);

                if (input) {
                    input.checked = isActive;
                }
            });

            document.querySelectorAll('[data-autopay-method-view]').forEach((view) => {
                const viewCode = view.dataset.autopayMethodView || '';
                const isActive = activeMethodCode !== null && viewCode === activeMethodCode;

                view.classList.toggle('hidden', !isActive);
            });
        };

        const syncBluepaymentInteractionState = () => {
            const state = getBluepaymentRetryState();
            const overlay = getBluepaymentProcessingOverlayElement();
            const paymentMethodList = getPaymentMethodListElement();
            const restrictToBluepayment = state.orderPlaced && isBluepaymentMethodCode(getActiveBluepaymentMethodCode());
            const showProcessingOverlay = state.paymentInProgress && !state.blikConfirmationVisible;

            syncBluepaymentBlikConfirmationVisibility();

            if (overlay) {
                overlay.style.display = showProcessingOverlay ? 'flex' : 'none';
                overlay.setAttribute('aria-hidden', showProcessingOverlay ? 'false' : 'true');
            }

            if (paymentMethodList) {
                paymentMethodList.setAttribute(
                    'aria-busy',
                    state.paymentInProgress ? 'true' : 'false'
                );
            }

            if (document.body) {
                document.body.style.cursor = showProcessingOverlay ? 'wait' : '';
            }

            document.querySelectorAll('[data-payment-method-option]').forEach((option) => {
                const methodCode = option.dataset.paymentMethodOption || '';
                const shouldDisable = state.paymentInProgress
                    || (restrictToBluepayment && !isBluepaymentMethodCode(methodCode));
                const methodInput = option.querySelector('input[name="payment-method-option"]');
                const methodLabel = option.querySelector('label');

                option.setAttribute('aria-disabled', shouldDisable ? 'true' : 'false');
                option.style.pointerEvents = shouldDisable ? 'none' : '';
                option.style.opacity = shouldDisable ? '0.55' : '';
                option.style.cursor = shouldDisable ? 'not-allowed' : '';

                if (methodLabel) {
                    methodLabel.style.cursor = shouldDisable ? 'not-allowed' : '';
                }

                if (methodInput) {
                    methodInput.disabled = shouldDisable;
                }
            });
        };

        const clearBluepaymentRetryTimers = () => {
            const state = getBluepaymentRetryState();

            clearTimeout(state.pollTimerId);
            clearTimeout(state.blikTimeoutId);

            state.pollTimerId = null;
            state.blikTimeoutId = null;
        };

        const setActiveBluepaymentMethodCode = (code, { dispatch = true, updateCheckout = true } = {}) => {
            const normalizedCode = isBluepaymentMethodCode(code) ? code : null;
            const state = getBluepaymentRetryState();
            const previousCode = state.activeMethodCode;

            state.activeMethodCode = normalizedCode;
            syncBluepaymentMethodViewState(normalizedCode);

            const methodRoot = getBluepaymentRootByMethodCode(normalizedCode);

            if (methodRoot) {
                initBluepaymentTree(methodRoot);
            }

            if (updateCheckout && normalizedCode) {
                setCheckoutPaymentMethodCode(normalizedCode);
            }

            if (dispatch && normalizedCode && normalizedCode !== previousCode) {
                window.dispatchEvent(new CustomEvent('checkout:payment:method-activate', {
                    detail: {
                        method: normalizedCode
                    }
                }));
            }

            syncBluepaymentInteractionState();
        };

        const syncBluepaymentRetryStateFromCheckout = () => {
            const checkoutMethodCode = getCheckoutPaymentMethodCode();

            if (isBluepaymentMethodCode(checkoutMethodCode)) {
                setActiveBluepaymentMethodCode(checkoutMethodCode, {
                    dispatch: false
                });
                return;
            }

            getBluepaymentRetryState().activeMethodCode = null;
            syncBluepaymentMethodViewState(null);
            syncBluepaymentInteractionState();
        };

        const registerBluepaymentMethod = (code) => {
            if (!isBluepaymentMethodCode(code) || hyvaCheckout.payment.getByCode(code)) {
                return;
            }

            hyvaCheckout.payment.registerMethod({
                code,
                method: {
                    async placeOrder() {
                        const component = window.bluepaymentHyva?.[code] || null;

                        if (!component) {
                            await hyvaCheckout.main.getWireComponent().placeOrder(hyvaCheckout.storage.data);
                            return false;
                        }

                        return component.placeOrder();
                    },
                    async canRedirect() {
                        return false;
                    }
                }
            });
        };

        const registerAvailableBluepaymentMethods = () => {
            document.querySelectorAll('#payment-method-list input[name="payment-method-option"]').forEach((input) => {
                registerBluepaymentMethod(input.value);
            });
        };

        const getBluepaymentRootByMethodCode = (methodCode) => {
            if (!isBluepaymentMethodCode(methodCode)) {
                return null;
            }

            const view = document.querySelector(`[data-autopay-method-view="${methodCode}"]`);

            return view?.querySelector('.autopay-hyva-component[x-data="bluepaymentMethod"]') || null;
        };

        const initBluepaymentTree = (element) => {
            if (!element || element._x_dataStack || !window.Alpine || typeof window.Alpine.initTree !== 'function') {
                return;
            }

            window.Alpine.initTree(element);
        };

        const syncGatewaySelectionState = (root, gatewayId) => {
            if (!root) {
                return;
            }

            const normalizedGatewayId = gatewayId !== null && gatewayId !== undefined && gatewayId !== ''
                ? Number(gatewayId)
                : null;

            root.dataset.selectedGatewayId = normalizedGatewayId === null || Number.isNaN(normalizedGatewayId)
                ? ''
                : String(normalizedGatewayId);

            root.querySelectorAll('.autopay-hyva-gateway[data-gateway-id]').forEach((button) => {
                const isSelected = normalizedGatewayId !== null
                    && !Number.isNaN(normalizedGatewayId)
                    && Number(button.dataset.gatewayId) === normalizedGatewayId;
                const indicator = button.querySelector('.autopay-hyva-gateway__indicator');
                const indicatorDot = button.querySelector('.autopay-hyva-gateway__indicator-dot');

                button.classList.toggle('autopay-hyva-gateway--selected', isSelected);
                button.classList.toggle('autopay-hyva-gateway--idle', !isSelected);
                button.setAttribute('aria-pressed', isSelected ? 'true' : 'false');

                if (indicator) {
                    indicator.classList.toggle('autopay-hyva-gateway__indicator--selected', isSelected);
                }

                if (indicatorDot) {
                    indicatorDot.classList.toggle('autopay-hyva-gateway__indicator-dot--selected', isSelected);
                }
            });
        };

        const syncExistingBluepaymentGatewayStates = () => {
            document.querySelectorAll('.autopay-hyva-component[data-selected-gateway-id]').forEach((root) => {
                syncGatewaySelectionState(root, root.dataset.selectedGatewayId || null);
            });
        };

        const syncCardSelectionState = (root, cardIndex) => {
            if (!root) {
                return;
            }

            const normalizedCardIndex = cardIndex !== null && cardIndex !== undefined && cardIndex !== ''
                ? Number(cardIndex)
                : null;

            root.dataset.selectedCardIndex = normalizedCardIndex === null || Number.isNaN(normalizedCardIndex)
                ? ''
                : String(normalizedCardIndex);

            root.querySelectorAll('.autopay-hyva-saved-card[data-card-index]').forEach((card) => {
                const isSelected = normalizedCardIndex !== null
                    && !Number.isNaN(normalizedCardIndex)
                    && Number(card.dataset.cardIndex) === normalizedCardIndex;
                const input = card.querySelector('.autopay-hyva-saved-card__input');
                const radio = card.querySelector('.autopay-hyva-saved-card__radio');
                const radioDot = card.querySelector('.autopay-hyva-saved-card__radio-dot');

                card.classList.toggle('autopay-hyva-saved-card--selected', isSelected);
                card.classList.toggle('autopay-hyva-saved-card--idle', !isSelected);

                if (input) {
                    input.checked = isSelected;
                }

                if (radio) {
                    radio.classList.toggle('autopay-hyva-saved-card__radio--selected', isSelected);
                }

                if (radioDot) {
                    radioDot.classList.toggle('autopay-hyva-saved-card__radio-dot--selected', isSelected);
                }
            });
        };

        const syncExistingBluepaymentCardStates = () => {
            document.querySelectorAll('.autopay-hyva-component[data-selected-card-index]').forEach((root) => {
                syncCardSelectionState(root, root.dataset.selectedCardIndex || null);
            });
        };

        const getBluepaymentComponent = (root) => {
            if (!root) {
                return null;
            }

            const methodCode = root.dataset.bluepaymentMethodCode || '';
            const registeredComponent = methodCode ? window.bluepaymentHyva?.[methodCode] || null : null;

            if (registeredComponent && typeof registeredComponent.selectGatewayOption === 'function') {
                return registeredComponent;
            }

            const alpineComponent = root._x_dataStack?.[0] || null;

            if (alpineComponent && typeof alpineComponent.selectGatewayOption === 'function') {
                return alpineComponent;
            }

            return null;
        };

        const getBluepaymentMagewireComponent = (root) => {
            if (!root || !window.Magewire || typeof window.Magewire.find !== 'function') {
                return null;
            }

            const wireRoot = root.closest('[wire\\:id]');
            const wireId = wireRoot?.getAttribute('wire:id') || null;

            if (!wireId) {
                return null;
            }

            try {
                return window.Magewire.find(wireId);
            } catch (error) {
                return null;
            }
        };

        let bluepaymentGatewayClickHandlerRegistered = false;

        const registerBluepaymentGatewayClickHandler = () => {
            if (bluepaymentGatewayClickHandlerRegistered) {
                return;
            }

            bluepaymentGatewayClickHandlerRegistered = true;

            document.addEventListener('click', (event) => {
                const button = event.target instanceof Element
                    ? event.target.closest('.autopay-hyva-gateway[data-gateway-id]')
                    : null;

                if (!button) {
                    return;
                }

                const root = button.closest('.autopay-hyva-component[x-data="bluepaymentMethod"]');
                const gatewayId = button.dataset.gatewayId || null;

                if (!root || gatewayId === null) {
                    return;
                }

                event.preventDefault();
                initBluepaymentTree(root);

                const component = getBluepaymentComponent(root);

                if (component) {
                    component.selectGatewayOption(gatewayId);
                    return;
                }

                syncGatewaySelectionState(root, gatewayId);

                const magewireComponent = getBluepaymentMagewireComponent(root);

                if (!magewireComponent) {
                    return;
                }

                if (typeof magewireComponent.selectGateway === 'function') {
                    magewireComponent.selectGateway(Number(gatewayId));
                    return;
                }

                if (typeof magewireComponent.call === 'function') {
                    magewireComponent.call('selectGateway', Number(gatewayId));
                }
            });
        };

        let bluepaymentMethodSelectionHandlerRegistered = false;

        const registerBluepaymentMethodSelectionHandler = () => {
            if (bluepaymentMethodSelectionHandlerRegistered) {
                return;
            }

            bluepaymentMethodSelectionHandlerRegistered = true;

            const handleMethodSelection = (event) => {
                const target = event.target instanceof Element ? event.target : null;
                const input = target?.matches('input[name="payment-method-option"]')
                    ? target
                    : target?.closest('label.autopay-hyva-method__label')?.querySelector('input[name="payment-method-option"]');

                if (!input) {
                    return;
                }

                const methodCode = input.value || '';
                const state = getBluepaymentRetryState();

                if (!state.orderPlaced) {
                    return;
                }

                if (state.paymentInProgress) {
                    event.preventDefault();
                    event.stopPropagation();
                    return;
                }

                if (!isBluepaymentMethodCode(methodCode)) {
                    if (isBluepaymentMethodCode(state.activeMethodCode)) {
                        event.preventDefault();
                        event.stopPropagation();
                        showBluepaymentAlert('<?= $escaper->escapeJs(__('This order can only be completed using Autopay methods.')) ?>');
                    }

                    return;
                }

                event.preventDefault();
                event.stopPropagation();
                scheduleBluepaymentAlertCleanup();

                if (state.activeMethodCode && state.activeMethodCode !== methodCode) {
                    const activeMethodRoot = getBluepaymentRootByMethodCode(state.activeMethodCode);
                    const activeMethodComponent = getBluepaymentComponent(activeMethodRoot);

                    activeMethodComponent?.cancelActivePaymentAttempt?.();
                }

                setActiveBluepaymentMethodCode(methodCode);
            };

            document.addEventListener('click', handleMethodSelection, true);
            document.addEventListener('change', handleMethodSelection, true);
        };

        let bluepaymentSavedCardClickHandlerRegistered = false;

        const registerBluepaymentSavedCardClickHandler = () => {
            if (bluepaymentSavedCardClickHandlerRegistered) {
                return;
            }

            bluepaymentSavedCardClickHandlerRegistered = true;

            document.addEventListener('click', (event) => {
                const card = event.target instanceof Element
                    ? event.target.closest('.autopay-hyva-saved-card[data-card-index]')
                    : null;

                if (!card) {
                    return;
                }

                const root = card.closest('.autopay-hyva-component[x-data="bluepaymentMethod"]');
                const cardIndex = card.dataset.cardIndex || null;

                if (!root || cardIndex === null) {
                    return;
                }

                event.preventDefault();
                initBluepaymentTree(root);

                const component = getBluepaymentComponent(root);

                if (component && typeof component.selectCardOption === 'function') {
                    component.selectCardOption(cardIndex);
                    return;
                }

