<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="bluepayment">
                <group id="hyva" translate="label" type="text" sortOrder="680" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Hyvä Checkout</label>
                    <field id="override_template" translate="label comment" type="select" sortOrder="10"
                           showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Override Hyvä payment list template</label>
                        <comment>Enable to replace the default Hyvä Checkout payment method list with the Autopay custom template.</comment>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    </field>
                </group>
            </group>
        </section>
    </system>
</config>
